model Order {
  id               String          @id @default(uuid())
  user_id          String
  order_number     String          @unique
  customer_name    String
  customer_email   String?
  customer_phone   String
  shipping_address String
  sub_total        Float
  total_amount     Float
  shipping_cost    Float
  tax              Float?
  discount         Float?
  coupon_code      String?
  coupon_value     String?
  customer_note    String?
  admin_note       String?
  invoice_url      String?
  userId           User            @relation(fields: [user_id], references: [id])
  address          Address         @relation(fields: [shipping_address], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  payments         Payment[]
  paymentRefunds   PaymentRefund[]
  orderItems       OrderItem[]
  testimonials     Testimonial[]

  @@map("orders")
}

model VendorOrder {
  id             String           @id @default(uuid())
  order_id       String
  store_id       String
  store_order_id String           @unique
  shipping_cost  String?
  sub_total      Float
  total_amount   Float
  status         OrderStatus
  status_log     OrderStatusLog[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  vendor         Vendor?          @relation(fields: [vendorId], references: [id])
  vendorId       String?
  store          Store?           @relation(fields: [storeId], references: [id])
  storeId        String?
  walletSettled Boolean @default(false)
  deliveredAt   DateTime?
  orderItems     OrderItem[]

  @@map("vendor_orders")
}

model OrderItem {
  id                 String         @id @default(uuid())
  vendor_order_id    String
  order_id           String
  product_variant_id String
  product_id         String
  quantity           Int
  price              Float
  product_name       String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  productId          Product        @relation(fields: [product_id], references: [id])
  vendorOrderId      VendorOrder    @relation(fields: [vendor_order_id], references: [id])
  variantId          ProductVariant @relation(fields: [product_variant_id], references: [id])
  order              Order          @relation(fields: [order_id], references: [id])

  @@map("order_item")
}

model OrderStatusLog {
  id            String      @id @default(uuid())
  status        OrderStatus
  changedBy     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  vendorOrder   VendorOrder @relation(fields: [vendorOrderId], references: [id])
  vendorOrderId String

  @@map("order_status_log")
}

model Payment {
  id                String          @id @default(uuid())
  order_id          String
  payment_provider  PaymentProvider
  amount            Float
  transaction_id    String          @unique
  payment_intent_id String?         @unique
  status            PaymentStatus   @default(PENDING)
  order             Order           @relation(fields: [order_id], references: [id])
  paymentRefunds    PaymentRefund[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("payments")
}

model PaymentRefund {
  id            String   @id @default(uuid())
  payment_id    String
  refund_amount Float
  order_id      String
  order         Order    @relation(fields: [order_id], references: [id])
  payment       Payment  @relation(fields: [payment_id], references: [id])
  refund_reason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payment_refunds")
}
